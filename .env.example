# Vercel Deployment Config
# 1. Add these to Vercel "Environment Variables" in Project Settings
# 2. IMPORTANT: SQLite will NOT work on Vercel. You MUST use a hosted 
#    database URL (PostgreSQL) like Neon.tech or Supabase.

DATABASE_URL="postgres://..."
JWT_SECRET="any-random-string"
GEMINI_API_KEY="..."
NODE_ENV=production
