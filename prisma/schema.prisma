// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String           @unique
  password        String
  credits         Int              @default(25)
  role            String           @default("user") // "user" | "admin"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  paymentRequests PaymentRequest[]
  creditHistory   CreditHistory[]
}

model CreditHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amount    Int // e.g., 5 for deduction, 50 for addition
  type      String // "added" | "deducted"
  reason    String? // e.g., "Image generation", "Plan purchase"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  plan      String // "50 Credits", "100 Credits", "200 Credits"
  amount    Int // Price in INR
  utrCode   String   @unique
  date      DateTime
  note      String?
  status    String   @default("pending") // "pending", "approved", "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
